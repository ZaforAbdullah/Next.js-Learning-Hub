# .dockerignore - Excludes files from Docker build context
# This speeds up builds and reduces image size

# Node modules (will be installed in container)
node_modules
npm-debug.log

# Next.js build output
.next
out

# Development files
.git
.gitignore
README.md
.env*.local
.env

# IDE files
.vscode
.idea
*.swp
*.swo
*~

# Testing
coverage
.nyc_output

# Misc
.DS_Store
*.pem

# Debug
yarn-debug.log*
yarn-error.log*

# Vercel
.vercel
